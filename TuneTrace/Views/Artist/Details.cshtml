@model TuneTrace.ViewModels.ArtistViewModel

<h1>@Model.Name</h1>
<p><strong>Music Career:</strong></p>
<p>@Model.Biography</p>

<form method="post" action="/User/AddFavouriteArtist" style="display:inline">
    <input type="hidden" name="artistId" value="@Model.Id" />
    <button type="submit">Add to Favourite</button>
</form>
<form method="post" action="/User/RemoveFavouriteArtist" style="display:inline">
    <input type="hidden" name="artistId" value="@Model.Id" />
    <button type="submit">Remove from Favourite</button>
</form>

<h3 style="margin-top: 30px;">Albums</h3>
@if (Model.Albums != null && Model.Albums.Count > 0)
{
    <ul>
        @foreach (var album in Model.Albums)
        {
            <li>@album.Title</li>
        }
    </ul>
}
else
{
    <p>No albums found for this artist.</p>
}

<h3 style="margin-top: 20px;">Songs</h3>
@if (Model.Songs != null && Model.Songs.Count > 0)
{
    <table style="width: 100%; border-collapse: collapse;">
        <tr>
            <th style="text-align:left; padding: 5px;">Title</th>
            <th style="text-align:left; padding: 5px;">Release Date</th>
            <th style="text-align:left; padding: 5px;">Duration</th>
        </tr>
        @foreach (var song in Model.Songs)
        {
            <tr>
                <td style="padding: 5px;">@song.Title</td>
                <td style="padding: 5px;">@song.ReleaseDate.ToString("yyyy-MM-dd")</td>
                <td style="padding: 5px;">@song.Duration</td>
            </tr>
        }
    </table>
}
else
{
    <p>No songs found for this artist.</p>
}

<br />
<a href="javascript:history.back()">Back</a>