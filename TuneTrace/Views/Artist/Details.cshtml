@model TuneTrace.ViewModels.ArtistViewModel

<h1>@Model.Name</h1>
<p><strong>Music Career:</strong></p>
<p>@Model.Biography</p>

<form method="post" action="/User/AddFavouriteArtist" style="display:inline">
    <input type="hidden" name="artistId" value="@Model.Id" />
    <button type="submit">Add to Favourite</button>
</form>
<form method="post" action="/User/RemoveFavouriteArtist" style="display:inline">
    <input type="hidden" name="artistId" value="@Model.Id" />
    <button type="submit">Remove from Favourite</button>
</form>

<h3 style="margin-top: 30px;">Albums</h3>
@if (Model.Albums != null && Model.Albums.Count > 0)
{
    <ul>
        @foreach (var album in Model.Albums)
        {
            <li>
                <a href="/Album/Details/@album.Id">@album.Title</a>
            </li>
        }
    </ul>
}
else
{
    <p>No albums found for this artist.</p>
}

<br />
<a asp-action="Index">Back</a>