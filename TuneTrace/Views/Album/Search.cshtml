@{
    ViewData["Title"] = "Search Albums";
}

<h2>Search Albums</h2>

<form method="get" action="/Album/Search">
    <input type="text" name="query" value="@ViewBag.Query" placeholder="Search albums..." />
    <button type="submit">Search</button>
</form>

@if (ViewBag.Error != null)
{
    <p style="color:red;">@ViewBag.Error</p>
}
else if (ViewBag.Albums != null && ViewBag.Albums.Count > 0)
{
    <ul>
        @foreach (var album in ViewBag.Albums)
        {
            <li>
                <a href="/Album/Details/@album.Id">@album.Title</a> — @album.Artist
            </li>
        }
    </ul>
}
else if (ViewBag.Query != null)
{
    <p>No results found for "@ViewBag.Query".</p>
}