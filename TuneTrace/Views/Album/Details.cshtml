@using TuneTrace.ViewModels
@{
    ViewData["Title"] = "Album Details";
    AlbumViewModel? album = ViewBag.Album;
    List<ReviewViewModel>? reviews = ViewBag.Reviews;
    string[] colors = { "#fff8e1", "#e8f5e9", "#e3f2fd", "#fce4ec", "#f3e5f5" };
}

<div style="max-width: 900px; margin: 40px auto; display: flex; gap: 40px;">
    <div style="flex: 1;">
        <h2>@(album?.Title ?? "Unknown")</h2>
        <p><strong>Artist:</strong> @(album?.ArtistName ?? "Unknown")</p>
        <p><strong>Release Date:</strong> @(album?.ReleaseDate.ToString("yyyy-MM-dd") ?? "Unknown")</p>
        <h3>Songs on this album:</h3>
        @if (album?.Songs != null && album.Songs.Count > 0)
        {
            <ul>
                @foreach (var song in album.Songs)
                {
                    <li>@song.Title — @song.Duration</li>
                }
            </ul>
        }
        else
        {
            <p>No songs found for this album.</p>
        }

        <form method="post" action="/User/AddFavouriteAlbum" style="display:inline">
            <input type="hidden" name="albumId" value="@album?.Id" />
            <button type="submit">Add to Favourite</button>
        </form>
        <form method="post" action="/User/RemoveFavouriteAlbum" style="display:inline">
            <input type="hidden" name="albumId" value="@album?.Id" />
            <button type="submit">Remove from Favourite</button>
        </form>
        <a href="/Review?albumId=@album?.Id" style="margin-left: 10px; text-decoration: none;">
            <input type="button" value="Add Rating & Review" />
        </a>
        <br /><br />
        <a href="javascript:history.back()">Back</a>
    </div>

    <div style="width: 300px; border: 1px solid #ccc; border-radius: 8px; padding: 15px;">
        <h3 style="margin-top: 0;">Reviews & Ratings</h3>
        <div style="max-height: 350px; overflow-y: auto;">
            @if (reviews != null && reviews.Count > 0)
            {
                @for (int i = 0; i < reviews.Count; i++)
                {
                    <div style="background-color: @colors[i % colors.Length]; border-radius: 6px; padding: 10px; margin-bottom: 8px;">
                        <strong>Rating:</strong> @reviews[i].Rating/10 <br />
                        @reviews[i].ReviewText
                    </div>
                }
            }
            else
            {
                <p>There are no Reviews and Ratings available.</p>
            }
        </div>
    </div>
</div>