@{
    ViewData["Title"] = "Reviews & Ratings";
}

<h1>Reviews & Ratings</h1>

@if (TempData["Wrong"] != null)
{
    <div class="alert alert-warning">@TempData["Wrong"]</div>
}

@if (TempData["Succes"] != null)
{
    <div class="alert alert-success">@TempData["Succes"]</div>
}

<div class="mt-4">
    <h4>Add a Review & Rating</h4>

    <div class="mb-3">
        <input type="radio" name="keuze" id="keuzeAlbum" value="album" onclick="toonAlbum()" checked /> Album
        &nbsp;
        <input type="radio" name="keuze" id="keuzeNummer" value="nummer" onclick="toonNummer()" /> Song
    </div>

    <form method="post" asp-controller="Beoordeling" asp-action="Opslaan">

        <div id="albumKeuze" class="mb-3">
            <label>Album</label>
            <select name="albumId" class="form-control">
                <option value="">-- Choose an album --</option>
                @foreach (var album in ViewBag.Albums)
                {
                    <option value="@album.Id">@album.Titel</option>
                }
            </select>
        </div>

        <div id="nummerKeuze" class="mb-3" style="display:none;">
            <label>Song</label>
            <select name="songId" class="form-control">
                <option value="">-- Choose a song --</option>
                @foreach (var song in ViewBag.Songs)
                {
                    <option value="@song.Id">@song.Titel</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label>Rating (1-10)</label>
            <input type="number" name="rating" min="1" max="10" class="form-control" required />
        </div>

        <div class="mb-3">
            <label>Review</label>
            <textarea name="review" class="form-control" rows="4"></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
    </form>
</div>

<div class="mt-5">
    <h4>My Reviews & Ratings</h4>

    @if (ViewBag.Beoordelingen.Count == 0)
    {
        <p>You have no reviews yet.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Item</th>
                    <th>Rating</th>
                    <th>Review</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in ViewBag.Beoordelingen)
                {
                    <tr>
                        <td>
                            @if (b.Album != null)
                            {
                                <span>Album: @b.Album.Titel</span>
                            }
                            else
                            {
                                <span>Song: @b.Song.Titel</span>
                            }
                        </td>
                        <td>@b.Rating / 10</td>
                        <td>@b.Review</td>
                        <td>
                            <form method="post" asp-controller="Beoordeling" asp-action="Verwijderen">
                                <input type="hidden" name="beoordelingId" value="@b.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<script src="~/js/beoordeling.js"></script>