@{
    ViewData["Title"] = "Home";
}

<div style="text-align: center; margin-bottom: 40px; border-bottom: 1px solid #dee2e6; padding-bottom: 20px;">
    <h1>Tune & Trace</h1>
    <p>Welcome to Tune & Trace — discover music, track your favourites and share your reviews!</p>
</div>

<div style="margin-top: 30px;">
    <h2 style="text-decoration: underline;">Toplists</h2>

    <table style="width: 100%; vertical-align: top; margin-top: 40px;">
        <tr>
            <td style="width: 33%; vertical-align: top; padding-right: 20px;">
                <h3>Songs</h3>
                @if (ViewBag.Songs != null && ViewBag.Songs.Count > 0)
                {
                    <ul>
                        @foreach (var song in ViewBag.Songs)
                        {
                            <li style="margin-bottom: 5px;">
                                <a href="/Song/Details/@song.Id">@song.Title</a><br />
                                <small>@song.Artist</small>
                            </li>
                        }
                    </ul>
                }
                else
                {

                    <p>No songs found.</p>
                }
            </td>
            <td style="width: 33%; vertical-align: top; padding-right: 20px;">
                <h3>Albums</h3>
                @if (ViewBag.Albums != null && ViewBag.Albums.Count > 0)
                {
                    <ul>
                        @foreach (var album in ViewBag.Albums)
                        {
                            <li style="margin-bottom: 5px;">
                                <a href="/Album/Details/@album.Id">@album.Title</a><br />
                                <small>@album.Artist</small>
                            </li>
                        }
                    </ul>
                }
                else
                {

                    <p>No albums found.</p>
                }
            </td>
            <td style="width: 33%; vertical-align: top;">
                <h3>Artists</h3>
                @if (ViewBag.Artists != null && ViewBag.Artists.Count > 0)
                {
                    <ul>
                        @foreach (var artist in ViewBag.Artists)
                        {
                            <li style="margin-bottom: 5px;">
                                <a href="/Artist/Details/@artist.Id">@artist.Name</a>
                            </li>
                        }
                    </ul>
                }
                else
                {

                    <p>No artists found.</p>
                }
            </td>
        </tr>
    </table>
</div>